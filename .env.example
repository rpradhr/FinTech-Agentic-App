# ──────────────────────────────────────────────
# FinTech Agentic App — Environment Variables
# Copy to .env and fill in values before running
# ──────────────────────────────────────────────

# App
APP_ENV=development         # development | staging | production
APP_SECRET_KEY=changeme-use-a-long-random-string
LOG_LEVEL=INFO

# Database — Couchbase / Capella
COUCHBASE_CONNECTION_STRING=couchbases://your-cluster.cloud.couchbase.com
COUCHBASE_USERNAME=your-db-user
COUCHBASE_PASSWORD=your-db-password
COUCHBASE_BUCKET=banking-core
COUCHBASE_VECTOR_INDEX=banking-vector-index

# AI / Capella AI Services
CAPELLA_AI_ENDPOINT=https://your-ai.cloud.couchbase.com
CAPELLA_AI_API_KEY=your-capella-ai-api-key
CAPELLA_MODEL_ID=gpt-4o              # model deployed in Capella Model Service
CAPELLA_EMBEDDING_MODEL_ID=text-embedding-3-small

# Fallback LLM (used when Capella AI is unavailable in dev/test)
OPENAI_API_KEY=sk-...               # optional: fallback in dev only
ANTHROPIC_API_KEY=...               # optional: fallback in dev only

# Auth / OIDC
OIDC_ISSUER_URL=https://your-idp.example.com
OIDC_CLIENT_ID=fintech-agentic-app
OIDC_CLIENT_SECRET=changeme
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem

# Event Bus (optional — set EVENTING_ENABLED=false to disable)
EVENTING_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTION_TOPIC=banking.transactions
KAFKA_INTERACTION_TOPIC=banking.interactions

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=fintech-agentic-app

# Frontend (served by FastAPI in dev; CDN origin in prod)
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
