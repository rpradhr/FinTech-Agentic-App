# FinTech Agentic frontend env

# Where the frontend talks to the FastAPI backend.
# Default "/api" goes through the Vite dev proxy → VITE_API_PROXY_TARGET.
# In production, set this to your full backend URL, e.g. https://api.yourdomain.com
VITE_API_BASE_URL=/api

# Dev-only: where the Vite proxy forwards /api/* requests
VITE_API_PROXY_TARGET=http://localhost:8000
